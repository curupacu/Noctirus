rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Nega tudo por padrão (RNF005). Papéis vêm de custom claims, nunca de campo público.
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    match /advogados/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    match /curriculos/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
