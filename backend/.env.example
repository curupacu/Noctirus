# Porta do servidor Express
PORT=3001

# Projeto Firebase (nocturis-web na nuvem, sem emulador)
FIREBASE_PROJECT_ID=nocturis-web

# Credenciais do Firebase Admin SDK (service account).
# Gere em: Firebase Console > Configurações do projeto > Contas de serviço > Gerar nova chave privada.
# Cole o JSON inteiro numa linha só (ou aponte para um arquivo local fora do repo).
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Chave do Google AI Studio (aistudio.google.com/apikey) pra triagem por IA (Sprint 5).
# Sem essa chave o backend não quebra: a triagem cai direto no fallback por regras.
GEMINI_API_KEY=
# Opcional — só se quiser trocar o modelo padrão.
GEMINI_MODEL=gemini-2.5-flash-lite
